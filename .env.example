# ====================
# App envs
# ====================
APP_KEY=
APP_NAME=Laravel
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=8000

# database app config
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=hrc
DB_USERNAME=user
DB_PASSWORD=passwd

VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5173

# ====================
# Docker compose envs
# ====================
# mysql
MYSQL_DATABASE=${DB_DATABASE}
MYSQL_PORT=${DB_PORT}
MYSQL_USER=${DB_USERNAME}
MYSQL_PASSWORD=${DB_PASSWORD}
MYSQL_ROOT_PASSWORD=${DB_PASSWORD}

# phpmyadmin
PMA_HOST=${DB_HOST}
PMA_PORT=${DB_PORT}
PMA_USER=${DB_USERNAME}
PMA_PASSWORD=${DB_PASSWORD}